# .env.example
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Server port (Render.com sets this automatically)
PORT=3000

# JWT secret key - change this to a long random string in production!
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Your deployed frontend URL (used for CORS)
# Leave as * for development, set to your actual URL in production
FRONTEND_URL=*
