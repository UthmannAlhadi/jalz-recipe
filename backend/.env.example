# ─── COPY THIS FILE TO .env FOR LOCAL DEVELOPMENT ───
# Never commit .env to GitHub.

# Server port (Render sets this automatically)
PORT=3000

# JWT secret — change this to any long random string
JWT_SECRET=change-this-to-a-long-random-string

# PostgreSQL connection string from Neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST/jalz_recipe?sslmode=require

# Cloudinary — for persistent image storage (free at cloudinary.com)
# Get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
